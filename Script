        BtnGolAway.BackgroundColor3 = _G.GrudarGolAway and Color3.fromRGB(75, 255, 75) or Color3.fromRGB(255, 75, 75)
    end)
end
-- ================= MOTOR DE FIXAÇÃO/TELEPORTE DO GOL NO SEU CORPO ================= --
local function ProcessarGrudeGols(hrp)
    local teams = Workspace:FindFirstChild("Teams", true)
    if not teams then return end

    local timeHome = teams:FindFirstChild("Home")
    if timeHome and timeHome:FindFirstChild("Goal") then
        local goal = timeHome.Goal
        local hitbox = goal:FindFirstChild("Hitbox")
        local intercept = goal:FindFirstChild("InterceptionHitbox")

        if hitbox and not hitbox:GetAttribute("CFrameOriginalGol") then hitbox:SetAttribute("CFrameOriginalGol", hitbox.CFrame) end
        if intercept and not intercept:GetAttribute("CFrameOriginalInt") then intercept:SetAttribute("CFrameOriginalInt", intercept.CFrame) end

        if _G.GrudarGolHome then
            if hitbox then hitbox.CFrame = hrp.CFrame end
            if intercept then intercept.CFrame = hrp.CFrame end
        else
            if hitbox and hitbox:GetAttribute("CFrameOriginalGol") then hitbox.CFrame = hitbox:GetAttribute("CFrameOriginalGol") end
            if intercept and intercept:GetAttribute("CFrameOriginalInt") then intercept.CFrame = intercept:GetAttribute("CFrameOriginalInt") end
        end
    end

    local timeAway = teams:FindFirstChild("Away")
    if timeAway and timeAway:FindFirstChild("Goal") then
        local goal = timeAway.Goal
        local hitbox = goal:FindFirstChild("Hitbox")
        local intercept = goal:FindFirstChild("InterceptionHitbox")

        if hitbox and not hitbox:GetAttribute("CFrameOriginalGol") then hitbox:SetAttribute("CFrameOriginalGol", hitbox.CFrame) end
        if intercept and not intercept:GetAttribute("CFrameOriginalInt") then intercept:SetAttribute("CFrameOriginalInt", intercept.CFrame) end

        if _G.GrudarGolAway then
            if hitbox then hitbox.CFrame = hrp.CFrame end
            if intercept then intercept.CFrame = hrp.CFrame end
        else
            if hitbox and hitbox:GetAttribute("CFrameOriginalGol") then hitbox.CFrame = hitbox:GetAttribute("CFrameOriginalGol") end
            if intercept and intercept:GetAttribute("CFrameOriginalInt") then intercept.CFrame = intercept:GetAttribute("CFrameOriginalInt") end
        end
    end
end

